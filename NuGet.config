<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Pin restore to nuget.org only, so builds are reproducible on any machine
    regardless of user-level private feeds. Required by Central Package
    Management (avoids NU1507 when multiple sources are configured).
    When internal packages are introduced, add the private feed here plus a
    <packageSourceMapping> entry scoped to its package prefix.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
