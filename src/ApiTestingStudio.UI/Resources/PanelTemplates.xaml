<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:panels="clr-namespace:ApiTestingStudio.UI.ViewModels.Panels"
                    xmlns:explorer="clr-namespace:ApiTestingStudio.UI.ViewModels.Explorer"
                    xmlns:runner="clr-namespace:ApiTestingStudio.UI.ViewModels.Runner"
                    xmlns:workflow="clr-namespace:ApiTestingStudio.UI.ViewModels.Workflow"
                    xmlns:views="clr-namespace:ApiTestingStudio.UI.Views.Panels"
                    xmlns:runnerViews="clr-namespace:ApiTestingStudio.UI.Views.Runner"
                    xmlns:workflowViews="clr-namespace:ApiTestingStudio.UI.Views.Workflow">

    <!--
        Implicit data templates mapping each panel view model to its view. AvalonDock renders the
        content of every document/tool pane through these templates. Adding a feature panel in a
        later sprint is a matter of adding its view model + view + one template here (or, for
        plugins, contributing an IToolWindow that the shell materialises the same way).
    -->

    <DataTemplate DataType="{x:Type panels:WelcomeDocumentViewModel}">
        <views:WelcomeDocumentView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type explorer:ServiceExplorerViewModel}">
        <views:ServiceExplorerView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type panels:LogsPlaceholderViewModel}">
        <views:LogsPlaceholderView />
    </DataTemplate>

    <!-- API Runner (Sprint 06) -->
    <DataTemplate DataType="{x:Type runner:ApiRunnerViewModel}">
        <runnerViews:ApiRunnerView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type runner:MonacoEditorViewModel}">
        <runnerViews:MonacoEditorView />
    </DataTemplate>

    <!-- Workflow Designer (Sprint 09) -->
    <DataTemplate DataType="{x:Type workflow:WorkflowsPanelViewModel}">
        <workflowViews:WorkflowsPanelView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type workflow:WorkflowEditorViewModel}">
        <workflowViews:WorkflowEditorView />
    </DataTemplate>

</ResourceDictionary>
