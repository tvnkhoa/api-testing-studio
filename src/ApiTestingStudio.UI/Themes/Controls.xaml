<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Control-style layer. Sits on top of the Material Design base theme (merged before this in
        App.xaml) and the design tokens in Tokens.xaml. Its job is to give controls a single,
        consistent chrome so views never set control padding/sizing inline.

        The implicit Button style is BasedOn the Material implicit Button style ({x:Type Button}),
        so Material chrome is preserved and only Padding is standardised. Buttons hosted inside a
        ToolBar are unaffected — WPF styles those via ToolBar's own ButtonStyleKey.
    -->
    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Padding" Value="{StaticResource Button.Padding}" />
    </Style>

    <!-- Compact variant for inline row actions (icon/tight buttons, e.g. list-row ✕ / Edit). -->
    <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Padding" Value="{StaticResource Button.Padding.Compact}" />
    </Style>

</ResourceDictionary>
