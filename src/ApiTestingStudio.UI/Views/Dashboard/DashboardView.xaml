<UserControl x:Class="ApiTestingStudio.UI.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:dash="clr-namespace:ApiTestingStudio.UI.ViewModels.Dashboard">
    <UserControl.Resources>
        <!-- Overview KPIs -->
        <DataTemplate DataType="{x:Type dash:OverviewWidgetViewModel}">
            <UniformGrid Columns="2" VerticalAlignment="Center">
                <StackPanel Margin="{StaticResource Spacing.Xs.Thickness}">
                    <TextBlock Text="Runs" Opacity="0.7" />
                    <TextBlock Text="{Binding RunCount}" FontSize="{StaticResource Typography.Headline}" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="{StaticResource Spacing.Xs.Thickness}">
                    <TextBlock Text="Success" Opacity="0.7" />
                    <TextBlock Text="{Binding SuccessRate}" FontSize="{StaticResource Typography.Headline}" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="{StaticResource Spacing.Xs.Thickness}">
                    <TextBlock Text="Avg duration" Opacity="0.7" />
                    <TextBlock Text="{Binding AverageDuration}" FontSize="{StaticResource Typography.Headline}" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Margin="{StaticResource Spacing.Xs.Thickness}">
                    <TextBlock Text="Failed" Opacity="0.7" />
                    <TextBlock Text="{Binding FailedCount}" FontSize="{StaticResource Typography.Headline}" FontWeight="Bold" />
                </StackPanel>
            </UniformGrid>
        </DataTemplate>

        <!-- Success rate donut -->
        <DataTemplate DataType="{x:Type dash:SuccessRateWidgetViewModel}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding Caption}"
                           HorizontalAlignment="Center"
                           Opacity="0.8"
                           Margin="{StaticResource Spacing.Xs.TopThickness}" />
                <lvc:PieChart Series="{Binding Series}" />
            </DockPanel>
        </DataTemplate>

        <!-- Latency line -->
        <DataTemplate DataType="{x:Type dash:LatencyWidgetViewModel}">
            <lvc:CartesianChart Series="{Binding Series}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}" />
        </DataTemplate>

        <!-- Slowest targets -->
        <DataTemplate DataType="{x:Type dash:SlowestTargetsWidgetViewModel}">
            <lvc:CartesianChart Series="{Binding Series}" YAxes="{Binding YAxes}" />
        </DataTemplate>

        <!-- Most-called targets -->
        <DataTemplate DataType="{x:Type dash:MostCalledTargetsWidgetViewModel}">
            <lvc:CartesianChart Series="{Binding Series}" YAxes="{Binding YAxes}" />
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="{StaticResource Spacing.Sm.Thickness}">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            <TextBlock Text="Live — updates as runs complete."
                       VerticalAlignment="Center"
                       Opacity="0.6"
                       Margin="{StaticResource Spacing.Md.LeftThickness}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Widgets}"
                          AutomationProperties.Name="Dashboard widgets">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="380"
                                Height="260"
                                Margin="{StaticResource Spacing.Sm.Thickness}"
                                Padding="{StaticResource Spacing.Sm.Thickness}"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="{StaticResource Border.Card.Brush}"
                                AutomationProperties.Name="{Binding Title}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Margin="{StaticResource Spacing.Sm.BottomThickness}" />
                                <ContentControl Content="{Binding}" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
