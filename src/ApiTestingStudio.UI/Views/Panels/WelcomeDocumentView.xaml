<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.WelcomeDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="{StaticResource Spacing.Xxl.Thickness}" VerticalAlignment="Top" MaxWidth="560" HorizontalAlignment="Left">
        <TextBlock Text="{Binding Headline}"
                   FontSize="{StaticResource Typography.Headline}"
                   FontWeight="Light"
                   Margin="{StaticResource Spacing.Md.BottomThickness}" />
        <TextBlock Text="{Binding Message}"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Left"
                   Opacity="0.8"
                   Margin="{StaticResource Spacing.Lg.BottomThickness}" />

        <TextBlock Text="Get started"
                   FontSize="{StaticResource Typography.Title}"
                   Margin="{StaticResource Spacing.Sm.BottomThickness}" />
        <WrapPanel>
            <Button Content="Open sample workspace"
                    Command="{Binding OpenSampleCommand}"
                    Padding="{StaticResource Button.Padding}"
                    Margin="{StaticResource Spacing.Sm.RightThickness}"
                    AutomationProperties.Name="Open sample workspace"
                    ToolTip="Create and open a small sample workspace to explore the product" />
            <Button Content="Import…"
                    Command="{Binding ImportCommand}"
                    Padding="{StaticResource Button.Padding}"
                    Margin="{StaticResource Spacing.Sm.RightThickness}"
                    AutomationProperties.Name="Import"
                    ToolTip="Import from OpenAPI, Postman, or cURL (requires an open workspace)" />
            <Button Content="Add service"
                    Command="{Binding AddServiceCommand}"
                    Padding="{StaticResource Button.Padding}"
                    AutomationProperties.Name="Add service"
                    ToolTip="Add a service to the catalog (requires an open workspace)" />
        </WrapPanel>

        <TextBlock Text="Tip: Open sample workspace works even before you create one."
                   FontSize="{StaticResource Typography.Caption}"
                   Opacity="0.7"
                   Margin="{StaticResource Spacing.Md.TopThickness}" />
    </StackPanel>
</UserControl>
