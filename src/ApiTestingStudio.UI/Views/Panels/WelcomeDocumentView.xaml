<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.WelcomeDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="{StaticResource Spacing.Xxl.Thickness}" VerticalAlignment="Top">
        <TextBlock Text="{Binding Headline}"
                   FontSize="{StaticResource Typography.Headline}"
                   FontWeight="Light"
                   Margin="{StaticResource Spacing.Md.BottomThickness}" />
        <TextBlock Text="{Binding Message}"
                   TextWrapping="Wrap"
                   MaxWidth="520"
                   HorizontalAlignment="Left"
                   Opacity="0.8" />
    </StackPanel>
</UserControl>
