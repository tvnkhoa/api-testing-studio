<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.StressRunnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Margin" Value="0,0,8,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricLabel">
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricValue">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <!-- Runner (plugin) status -->
            <Border Padding="8" Margin="0,0,0,10" Background="#22808080" CornerRadius="4">
                <TextBlock Text="{Binding RunnerStatus}" FontWeight="SemiBold" TextWrapping="Wrap" />
            </Border>

            <!-- Configuration -->
            <TextBlock Text="Configuration" FontWeight="Bold" Margin="0,0,0,6" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Target" Style="{StaticResource FieldLabel}" />
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                          ItemsSource="{Binding Targets}"
                          SelectedItem="{Binding SelectedTarget}"
                          DisplayMemberPath="Label" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Mode" Style="{StaticResource FieldLabel}" />
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
                          ItemsSource="{Binding Modes}"
                          SelectedItem="{Binding SelectedMode}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Virtual users" Style="{StaticResource FieldLabel}" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"
                         Text="{Binding VirtualUsers, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Concurrent workers (concurrent mode)." />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Iterations" Style="{StaticResource FieldLabel}" />
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6"
                         Text="{Binding Iterations, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Total request budget (loop / concurrent modes)." />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Duration (s)" Style="{StaticResource FieldLabel}" />
                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,6"
                         Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Concurrent-mode time limit; 0 means iteration-bounded." />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Warm-up" Style="{StaticResource FieldLabel}" />
                <TextBox Grid.Row="5" Grid.Column="1"
                         Text="{Binding WarmupIterations, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Invocations excluded from the metrics." />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Run" MinWidth="90" Margin="0,0,8,0" Command="{Binding RunCommand}" />
                <Button Content="Stop" MinWidth="90" Command="{Binding RunCancelCommand}"
                        IsEnabled="{Binding IsRunning}" />
            </StackPanel>

            <!-- Live metrics -->
            <TextBlock Text="Live metrics" FontWeight="Bold" Margin="0,0,0,6" />
            <Border Padding="12" Background="#18808080" CornerRadius="4">
                <Grid DataContext="{Binding LiveMetrics}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Completed" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding Completed}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock Text="Failed" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding Failed}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Req/s (TPS)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding RequestsPerSecond, StringFormat=F1}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3">
                        <TextBlock Text="Error rate" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding ErrorRate, StringFormat=P1}" Style="{StaticResource MetricValue}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="Min (ms)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding MinMs, StringFormat=F1}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1">
                        <TextBlock Text="Avg (ms)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding AverageMs, StringFormat=F1}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Max (ms)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding MaxMs, StringFormat=F1}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="3">
                        <TextBlock Text="Elapsed (s)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding ElapsedSeconds, StringFormat=F1}" Style="{StaticResource MetricValue}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="P50 (ms)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding P50Ms, StringFormat=F0}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBlock Text="P95 (ms)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding P95Ms, StringFormat=F0}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="P99 (ms)" Style="{StaticResource MetricLabel}" />
                        <TextBlock Text="{Binding P99Ms, StringFormat=F0}" Style="{StaticResource MetricValue}" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="{Binding LastRunSummary}" Margin="0,10,0,0" TextWrapping="Wrap" FontWeight="SemiBold" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
