<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:panels="clr-namespace:ApiTestingStudio.UI.ViewModels.Panels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Run list -->
        <DockPanel Grid.Column="0" Margin="{StaticResource Spacing.Sm.Thickness}">
            <TextBlock DockPanel.Dock="Top" Text="Runs" FontWeight="SemiBold" Margin="{StaticResource Spacing.Sm.BottomThickness}" />
            <TextBlock DockPanel.Dock="Top"
                       Text="No runs recorded yet."
                       Opacity="0.7"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />
            <ListBox ItemsSource="{Binding Runs}"
                     SelectedItem="{Binding SelectedRun}"
                     AutomationProperties.Name="Runs"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.CanContentScroll="True">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="{StaticResource Spacing.Xs.VerticalThickness}">
                            <TextBlock Text="{Binding Display}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Opacity="0.7">
                                <TextBlock Text="{Binding Source}" />
                                <TextBlock Text="·" Margin="{StaticResource Spacing.Sm.HorizontalThickness}" />
                                <TextBlock Text="{Binding Status}" />
                                <TextBlock Text="·" Margin="{StaticResource Spacing.Sm.HorizontalThickness}" />
                                <TextBlock Text="{Binding When}" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Detail: step tree + replay -->
        <DockPanel Grid.Column="1" Margin="{StaticResource Spacing.Sm.Thickness}">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="{StaticResource Spacing.Sm.BottomThickness}">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="{StaticResource Spacing.Sm.RightThickness}" />
                <Button Content="Replay" Command="{Binding ReplayCommand}" />
            </StackPanel>
            <TreeView ItemsSource="{Binding Steps}"
                      AutomationProperties.Name="Run steps"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type panels:RunStepNode}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Kind}" Opacity="0.6" Margin="{StaticResource Spacing.Sm.LeftThickness}" />
                            <TextBlock Text="{Binding Detail}" Opacity="0.85" Margin="{StaticResource Spacing.Md.LeftThickness}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
        </DockPanel>
    </Grid>
</UserControl>
