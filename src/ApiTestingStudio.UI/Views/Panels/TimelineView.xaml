<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:panels="clr-namespace:ApiTestingStudio.UI.ViewModels.Panels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Run list -->
        <DockPanel Grid.Column="0" Margin="8">
            <TextBlock DockPanel.Dock="Top" Text="Runs" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock DockPanel.Dock="Top"
                       Text="No runs recorded yet."
                       Opacity="0.7"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />
            <ListBox ItemsSource="{Binding Runs}"
                     SelectedItem="{Binding SelectedRun}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="{Binding Display}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Opacity="0.7">
                                <TextBlock Text="{Binding Source}" />
                                <TextBlock Text="·" Margin="6,0" />
                                <TextBlock Text="{Binding Status}" />
                                <TextBlock Text="·" Margin="6,0" />
                                <TextBlock Text="{Binding When}" />
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Detail: step tree + replay -->
        <DockPanel Grid.Column="1" Margin="0,8,8,8">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="Refresh" Padding="12,2" Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                <Button Content="Replay" Padding="12,2" Command="{Binding ReplayCommand}" />
            </StackPanel>
            <TreeView ItemsSource="{Binding Steps}">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type panels:RunStepNode}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Kind}" Opacity="0.6" Margin="8,0,0,0" />
                            <TextBlock Text="{Binding Detail}" Opacity="0.85" Margin="12,0,0,0" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
            </TreeView>
        </DockPanel>
    </Grid>
</UserControl>
