<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.TestResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:enums="clr-namespace:ApiTestingStudio.Domain.Enums;assembly=ApiTestingStudio.Domain">
    <DockPanel LastChildFill="True" Margin="8">
        <Border DockPanel.Dock="Top" Padding="8" Margin="0,0,0,8" Background="#22808080" CornerRadius="4">
            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" TextWrapping="Wrap" />
        </Border>

        <TreeView ItemsSource="{Binding Cases}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Assertions}">
                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RunStatus.Passed}">
                                        <Setter Property="Foreground" Value="#2E7D32" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static enums:RunStatus.Failed}">
                                        <Setter Property="Foreground" Value="#C62828" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <HierarchicalDataTemplate.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Outcome}" Value="{x:Static enums:AssertionOutcome.Passed}">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Outcome}" Value="{x:Static enums:AssertionOutcome.Failed}">
                                                <Setter Property="Foreground" Value="#C62828" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Outcome}" Value="{x:Static enums:AssertionOutcome.Skipped}">
                                                <Setter Property="Foreground" Value="#9E9E9E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </DockPanel>
</UserControl>
