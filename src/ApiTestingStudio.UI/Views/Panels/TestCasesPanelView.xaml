<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.TestCasesPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="{StaticResource Spacing.Xs.Thickness}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Suites -->
        <DockPanel Grid.Row="0" LastChildFill="True">
            <ToolBarTray DockPanel.Dock="Top">
                <ToolBar>
                    <TextBlock Text="Suites" FontWeight="SemiBold" VerticalAlignment="Center" Margin="{StaticResource Spacing.Sm.RightThickness}" />
                    <Button Content="New" Command="{Binding NewSuiteCommand}" ToolTip="Create a new test suite" />
                    <Button Content="Delete" Command="{Binding DeleteSuiteCommand}" ToolTip="Delete the selected suite" />
                    <Separator />
                    <Button Content="Run Suite" Command="{Binding RunSuiteCommand}" ToolTip="Run every case in the suite" />
                </ToolBar>
            </ToolBarTray>
            <ListBox ItemsSource="{Binding Suites}"
                     SelectedItem="{Binding SelectedSuite}"
                     DisplayMemberPath="Name"
                     Margin="{StaticResource Spacing.Xs.Thickness}"
                     AutomationProperties.Name="Test suites" />
        </DockPanel>

        <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="Transparent"
                      AutomationProperties.Name="Resize suites and cases" />

        <!-- Cases -->
        <DockPanel Grid.Row="2" LastChildFill="True">
            <ToolBarTray DockPanel.Dock="Top">
                <ToolBar>
                    <TextBlock Text="Cases" FontWeight="SemiBold" VerticalAlignment="Center" Margin="{StaticResource Spacing.Sm.RightThickness}" />
                    <Button Content="New" Command="{Binding NewCaseCommand}" ToolTip="Create a new test case in the selected suite" />
                    <Button Content="Edit" Command="{Binding EditCaseCommand}" ToolTip="Edit the selected case" />
                    <Button Content="Delete" Command="{Binding DeleteCaseCommand}" ToolTip="Delete the selected case" />
                    <Separator />
                    <Button Content="Run Case" Command="{Binding RunCaseCommand}" ToolTip="Run the selected case" />
                </ToolBar>
            </ToolBarTray>
            <ListBox ItemsSource="{Binding Cases}"
                     SelectedItem="{Binding SelectedCase}"
                     DisplayMemberPath="Name"
                     Margin="{StaticResource Spacing.Xs.Thickness}"
                     AutomationProperties.Name="Test cases" />
        </DockPanel>

        <GridSplitter Grid.Row="3" Height="4" HorizontalAlignment="Stretch" Background="Transparent"
                      AutomationProperties.Name="Resize cases and assertions" />

        <!-- Assertions -->
        <DockPanel Grid.Row="4" LastChildFill="True">
            <ToolBarTray DockPanel.Dock="Top">
                <ToolBar>
                    <TextBlock Text="Assertions" FontWeight="SemiBold" VerticalAlignment="Center" Margin="{StaticResource Spacing.Sm.RightThickness}" />
                    <Button Content="New" Command="{Binding NewAssertionCommand}" ToolTip="Attach a new assertion to the selected case" />
                    <Button Content="Edit" Command="{Binding EditAssertionCommand}" ToolTip="Edit the selected assertion" />
                    <Button Content="Delete" Command="{Binding DeleteAssertionCommand}" ToolTip="Delete the selected assertion" />
                </ToolBar>
            </ToolBarTray>
            <ListBox ItemsSource="{Binding Assertions}"
                     SelectedItem="{Binding SelectedAssertion}"
                     Margin="{StaticResource Spacing.Xs.Thickness}"
                     AutomationProperties.Name="Assertions">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Kind}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Source}" Opacity="0.7" Margin="{StaticResource Spacing.Sm.LeftThickness}" />
                            <TextBlock Text="{Binding Expression}" Opacity="0.7" Margin="{StaticResource Spacing.Sm.LeftThickness}" />
                            <TextBlock Text="🚫" Margin="{StaticResource Spacing.Sm.LeftThickness}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
