<UserControl x:Class="ApiTestingStudio.UI.Views.Panels.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
    <DockPanel LastChildFill="True">
        <!-- Filter bar -->
        <Grid DockPanel.Dock="Top" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Level" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox Grid.Column="1"
                      Width="120"
                      Margin="0,0,12,0"
                      ItemsSource="{Binding LevelOptions}"
                      SelectedItem="{Binding SelectedLevel}" />

            <TextBlock Grid.Column="2" Text="Source" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox Grid.Column="3"
                      Width="200"
                      Margin="0,0,12,0"
                      ItemsSource="{Binding SourceOptions}"
                      SelectedItem="{Binding SelectedSource}" />

            <TextBox Grid.Column="4"
                     Margin="0,0,12,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=250}" />

            <Button Grid.Column="5"
                    Content="Refresh"
                    Padding="12,2"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Margin="12,8"
                   Opacity="0.7"
                   Text="No log events match the current filters."
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />

        <DataGrid ItemsSource="{Binding Events}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  Margin="8,0,8,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"
                                    Binding="{Binding TimestampUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                    Width="150" />
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="90" />
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="220" />
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
