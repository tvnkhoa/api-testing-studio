<UserControl x:Class="ApiTestingStudio.UI.Views.Runner.ApiRunnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>

        <!-- Main request/response area -->
        <Grid Grid.Column="0" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <!-- Request line: method + url + send/cancel -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" MinWidth="90" VerticalContentAlignment="Center"
                          ItemsSource="{Binding Builder.Methods}"
                          SelectedItem="{Binding Builder.Method}" />
                <TextBox Grid.Column="1" Margin="6,0" VerticalContentAlignment="Center"
                         Text="{Binding Builder.Url, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Request URL" />
                <Button Grid.Column="2" Content="Send" MinWidth="72" Padding="12,4"
                        Command="{Binding SendCommand}" />
                <Button Grid.Column="3" Content="Cancel" MinWidth="60" Margin="6,0,0,0" Padding="8,4"
                        Command="{Binding SendCancelCommand}" />
            </Grid>

            <!-- Request builder tabs -->
            <TabControl Grid.Row="1" Margin="0,8,0,0">
                <TabItem Header="Params">
                    <DataGrid ItemsSource="{Binding Builder.QueryParams}"
                              AutoGenerateColumns="False" CanUserAddRows="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Binding="{Binding Enabled}" Width="30" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Headers">
                    <DataGrid ItemsSource="{Binding Builder.Headers}"
                              AutoGenerateColumns="False" CanUserAddRows="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Binding="{Binding Enabled}" Width="30" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Body">
                    <DockPanel>
                        <ToolBarTray DockPanel.Dock="Top">
                            <ToolBar>
                                <ComboBox MinWidth="80" ItemsSource="{Binding Builder.BodyKinds}"
                                          SelectedItem="{Binding Builder.BodyKind}" />
                                <Button Content="Format" Command="{Binding Builder.Body.FormatCommand}"
                                        ToolTip="Pretty-print JSON body" />
                            </ToolBar>
                        </ToolBarTray>
                        <ContentControl Content="{Binding Builder.Body}" />
                    </DockPanel>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Margin="0,4" />

            <!-- Response -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            Visibility="{Binding Response.HasResponse, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding Response.StatusText}" FontWeight="SemiBold" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding Response.SizeText}" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding Response.TimingText}" Opacity="0.8" />
                </StackPanel>

                <TabControl Grid.Row="1" Margin="0,6,0,0">
                    <TabItem Header="Body">
                        <ContentControl Content="{Binding Response.Body}" />
                    </TabItem>
                    <TabItem Header="Headers">
                        <DataGrid ItemsSource="{Binding Response.Headers}"
                                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <!-- History -->
        <DockPanel Grid.Column="2" Margin="4,8,8,8">
            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="History" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Replay" Margin="0,0,4,0" Padding="6,2"
                        Command="{Binding ReplayCommand}" />
                <Button Grid.Column="2" Content="Clear" Padding="6,2"
                        Command="{Binding ClearHistoryCommand}" />
            </Grid>

            <ListBox Margin="0,6,0,0"
                     ItemsSource="{Binding History}"
                     SelectedItem="{Binding SelectedHistoryEntry}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Method}" FontWeight="SemiBold" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding StatusCode}" />
                            </StackPanel>
                            <TextBlock Text="{Binding TimestampUtc, StringFormat=g}" FontSize="10" Opacity="0.7" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
