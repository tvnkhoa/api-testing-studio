<UserControl x:Class="ApiTestingStudio.UI.Views.Runner.ApiRunnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>

        <!-- Main request/response area -->
        <Grid Grid.Column="0" Margin="{StaticResource Spacing.Sm.Thickness}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <!-- Request line: method + url + send/cancel -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" MinWidth="90" VerticalContentAlignment="Center"
                          ItemsSource="{Binding Builder.Methods}"
                          SelectedItem="{Binding Builder.Method}"
                          AutomationProperties.Name="HTTP method" />
                <TextBox Grid.Column="1" Margin="{StaticResource Spacing.Sm.HorizontalThickness}" VerticalContentAlignment="Center"
                         Text="{Binding Builder.Url, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Request URL"
                         ToolTip="Request URL" />
                <Button Grid.Column="2" Content="Send" MinWidth="72" Command="{Binding SendCommand}"
                        AutomationProperties.Name="Send request" />
                <Button Grid.Column="3" Content="Cancel" MinWidth="60" Margin="{StaticResource Spacing.Sm.LeftThickness}"
                        Command="{Binding SendCancelCommand}"
                        AutomationProperties.Name="Cancel request" />
            </Grid>

            <!-- Request builder tabs -->
            <TabControl Grid.Row="1" Margin="{StaticResource Spacing.Sm.TopThickness}">
                <TabItem Header="Params">
                    <DataGrid ItemsSource="{Binding Builder.QueryParams}"
                              AutoGenerateColumns="False" CanUserAddRows="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Binding="{Binding Enabled}" Width="30" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Headers">
                    <DataGrid ItemsSource="{Binding Builder.Headers}"
                              AutoGenerateColumns="False" CanUserAddRows="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="" Binding="{Binding Enabled}" Width="30" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Body">
                    <DockPanel>
                        <ToolBarTray DockPanel.Dock="Top">
                            <ToolBar>
                                <ComboBox MinWidth="80" ItemsSource="{Binding Builder.BodyKinds}"
                                          SelectedItem="{Binding Builder.BodyKind}" />
                                <Button Content="Format" Command="{Binding Builder.Body.FormatCommand}"
                                        ToolTip="Pretty-print JSON body" />
                            </ToolBar>
                        </ToolBarTray>
                        <ContentControl Content="{Binding Builder.Body}" />
                    </DockPanel>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Margin="{StaticResource Spacing.Xs.VerticalThickness}"
                          AutomationProperties.Name="Resize request and response areas" />

            <!-- Response -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Unresolved-variable warning: shown when the last send substituted empty values. -->
                <Border Grid.Row="0" Background="{StaticResource Semantic.Warning.Brush}"
                        Padding="{StaticResource Spacing.Sm.Thickness}" Margin="{StaticResource Spacing.Sm.BottomThickness}"
                        Visibility="{Binding HasWarning, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding WarningMessage}" TextWrapping="Wrap"
                               Foreground="{StaticResource Text.OnAccent.Brush}"
                               AutomationProperties.Name="Unresolved variable warning" />
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            Visibility="{Binding Response.HasResponse, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding Response.StatusText}" FontWeight="SemiBold" Margin="{StaticResource Spacing.Lg.RightThickness}" />
                    <TextBlock Text="{Binding Response.SizeText}" Margin="{StaticResource Spacing.Lg.RightThickness}" />
                    <TextBlock Text="{Binding Response.TimingText}" Opacity="0.8" />
                </StackPanel>

                <TabControl Grid.Row="2" Margin="{StaticResource Spacing.Sm.TopThickness}">
                    <TabItem Header="Body">
                        <ContentControl Content="{Binding Response.Body}" />
                    </TabItem>
                    <TabItem Header="Headers">
                        <DataGrid ItemsSource="{Binding Response.Headers}"
                                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      AutomationProperties.Name="Resize request/response and history areas" />

        <!-- History -->
        <DockPanel Grid.Column="2" Margin="{StaticResource Spacing.Sm.Thickness}">
            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="History" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Replay" Margin="{StaticResource Spacing.Xs.RightThickness}"                        Command="{Binding ReplayCommand}" />
                <Button Grid.Column="2" Content="Clear"                        Command="{Binding ClearHistoryCommand}" />
            </Grid>

            <ListBox Margin="{StaticResource Spacing.Sm.TopThickness}"
                     ItemsSource="{Binding History}"
                     SelectedItem="{Binding SelectedHistoryEntry}"
                     AutomationProperties.Name="Request history">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Method}" FontWeight="SemiBold" Margin="{StaticResource Spacing.Sm.RightThickness}" />
                                <TextBlock Text="{Binding StatusCode}" />
                            </StackPanel>
                            <TextBlock Text="{Binding TimestampUtc, StringFormat=g}" FontSize="{StaticResource Typography.Caption}" Opacity="0.7" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
