<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.ProfileEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ApiTestingStudio.UI.Behaviors"
        Title="{Binding Title}"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- Secret controls swap between masked (PasswordBox) and revealed (TextBox) on RevealSecrets. -->
        <Style x:Key="SecretPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RevealSecrets}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecretTextStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RevealSecrets}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="Name" />
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Role" />
                <ComboBox ItemsSource="{Binding Kinds}" SelectedItem="{Binding Kind}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Auth scheme" />
                <ComboBox ItemsSource="{Binding Schemes}" SelectedItem="{Binding Auth}" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <TextBlock Text="API key header name" Margin="0,12,0,0" />
        <TextBox Text="{Binding ApiKeyHeaderName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />

        <TextBlock Text="Username" Margin="0,12,0,0" />
        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />

        <TextBlock Text="Email" Margin="0,12,0,0" />
        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Tenant" />
                <TextBox Text="{Binding Tenant, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="User id" />
                <TextBox Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <Separator Margin="0,16,0,8" />
        <DockPanel>
            <TextBlock Text="Secrets" FontWeight="SemiBold" />
            <CheckBox Content="Reveal" IsChecked="{Binding RevealSecrets}" HorizontalAlignment="Right" />
        </DockPanel>
        <TextBlock Text="{Binding SecretHint}" Opacity="0.7" FontStyle="Italic" Margin="0,2,0,0" />

        <TextBlock Text="Access token" Margin="0,8,0,0" />
        <PasswordBox Style="{StaticResource SecretPasswordStyle}" behaviors:PasswordBoxBehavior.BoundPassword="{Binding AccessToken, Mode=TwoWay}" />
        <TextBox Style="{StaticResource SecretTextStyle}" Text="{Binding AccessToken, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Refresh token" Margin="0,8,0,0" />
        <PasswordBox Style="{StaticResource SecretPasswordStyle}" behaviors:PasswordBoxBehavior.BoundPassword="{Binding RefreshToken, Mode=TwoWay}" />
        <TextBox Style="{StaticResource SecretTextStyle}" Text="{Binding RefreshToken, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Password" Margin="0,8,0,0" />
        <PasswordBox Style="{StaticResource SecretPasswordStyle}" behaviors:PasswordBoxBehavior.BoundPassword="{Binding Password, Mode=TwoWay}" />
        <TextBox Style="{StaticResource SecretTextStyle}" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="API key" Margin="0,8,0,0" />
        <PasswordBox Style="{StaticResource SecretPasswordStyle}" behaviors:PasswordBoxBehavior.BoundPassword="{Binding ApiKey, Mode=TwoWay}" />
        <TextBox Style="{StaticResource SecretTextStyle}" Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="Secret" Margin="0,8,0,0" />
        <PasswordBox Style="{StaticResource SecretPasswordStyle}" behaviors:PasswordBoxBehavior.BoundPassword="{Binding Secret, Mode=TwoWay}" />
        <TextBox Style="{StaticResource SecretTextStyle}" Text="{Binding Secret, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="0,0,8,0" />
            <Button Content="OK" IsDefault="True" MinWidth="80" IsEnabled="{Binding CanConfirm}" Click="OnConfirm" />
        </StackPanel>
    </StackPanel>
</Window>
