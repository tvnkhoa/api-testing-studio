<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.ImportWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import"
        Width="560"
        Height="560"
        MinWidth="480"
        MinHeight="420"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel Margin="{StaticResource Spacing.Lg.Thickness}">
        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource Spacing.Lg.TopThickness}">
            <Button Content="Back"
                    MinWidth="80"
                    Margin="{StaticResource Spacing.Sm.RightThickness}"
                    Command="{Binding BackCommand}"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}" />
            <Button Content="Cancel"
                    IsCancel="True"
                    MinWidth="80"
                    Margin="{StaticResource Spacing.Sm.RightThickness}"
                    Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVis}}" />
            <Button MinWidth="90"
                    IsDefault="True"
                    Content="{Binding PrimaryButtonText}"
                    Command="{Binding PrimaryCommand}"
                    Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVis}}" />
            <Button Content="Close"
                    MinWidth="90"
                    IsDefault="True"
                    Click="OnClose"
                    Visibility="{Binding IsResultStep, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Busy + error banner -->
        <StackPanel DockPanel.Dock="Bottom">
            <ProgressBar Height="4"
                         IsIndeterminate="True"
                         Margin="{StaticResource Spacing.Sm.TopThickness}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource Semantic.Error.Brush}"
                       TextWrapping="Wrap"
                       Margin="{StaticResource Spacing.Sm.TopThickness}"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Step content -->
        <Grid>
            <!-- Source step -->
            <StackPanel Visibility="{Binding IsSourceStep, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Choose a source" FontWeight="Bold" Margin="{StaticResource Spacing.Sm.BottomThickness}" />

                <RadioButton GroupName="src" Content="Paste text (cURL, OpenAPI, Postman)"
                             IsChecked="{Binding IsPasteMode}" />
                <TextBox Margin="{StaticResource Spacing.SubItemIndent.Thickness}"
                         Height="140"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         IsEnabled="{Binding IsPasteMode}"
                         Text="{Binding PastedText, UpdateSourceTrigger=PropertyChanged}" />

                <RadioButton GroupName="src" Content="From file" Margin="{StaticResource Spacing.Md.TopThickness}"
                             IsChecked="{Binding IsFileMode}" />
                <Grid Margin="{StaticResource Spacing.SubItemIndent.Thickness}" IsEnabled="{Binding IsFileMode}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" IsReadOnly="True" Text="{Binding FilePath}" />
                    <Button Grid.Column="1" Content="Browse…" MinWidth="80" Margin="{StaticResource Spacing.Sm.LeftThickness}"
                            Command="{Binding BrowseCommand}" />
                </Grid>

                <RadioButton GroupName="src" Content="From URL (Swagger / OpenAPI / Scalar)" Margin="{StaticResource Spacing.Md.TopThickness}"
                             IsChecked="{Binding IsUrlMode}" />
                <TextBox Margin="{StaticResource Spacing.SubItemIndent.Thickness}"
                         IsEnabled="{Binding IsUrlMode}"
                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="{StaticResource Spacing.SubItemIndent.Thickness}"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           TextWrapping="Wrap"
                           Text="A base URL is probed for common definition paths. Network access happens only when you click Next." />
            </StackPanel>

            <!-- Preview step -->
            <DockPanel Visibility="{Binding IsPreviewStep, Converter={StaticResource BoolToVis}}">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Margin="{StaticResource Spacing.Xs.BottomThickness}">
                        <Run Text="Detected format:" FontWeight="Bold" />
                        <Run Text="{Binding PreviewFormat, Mode=OneWay}" />
                        <Run Text="  —  " />
                        <Run Text="{Binding PreviewEndpointCount, Mode=OneWay}" />
                        <Run Text="endpoint(s)" />
                    </TextBlock>
                    <CheckBox Content="Overwrite endpoints that already exist (same method + path)"
                              Margin="{StaticResource Spacing.Sm.VerticalThickness}"
                              IsChecked="{Binding OverwriteExisting}" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PreviewServices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Border.Card.Brush}" BorderThickness="1" CornerRadius="3" Padding="{StaticResource Spacing.Sm.Thickness}" Margin="{StaticResource Spacing.Sm.BottomThickness}">
                                    <StackPanel>
                                        <TextBlock>
                                            <Run Text="{Binding Change, Mode=OneWay}" FontWeight="Bold" />
                                            <Run Text=" service: " />
                                            <Run Text="{Binding Name, Mode=OneWay}" FontWeight="Bold" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding BaseUrl, Mode=OneWay}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                        <ItemsControl ItemsSource="{Binding Endpoints}" Margin="{StaticResource Spacing.Md.LeftThickness}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <Run Text="[" /><Run Text="{Binding Change, Mode=OneWay}" /><Run Text="] " />
                                                        <Run Text="{Binding Method, Mode=OneWay}" FontWeight="Bold" />
                                                        <Run Text="{Binding Path, Mode=OneWay}" />
                                                        <Run Text=" — " />
                                                        <Run Text="{Binding Name, Mode=OneWay}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- Result step -->
            <StackPanel Visibility="{Binding IsResultStep, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Import complete" FontWeight="Bold" Margin="{StaticResource Spacing.Sm.BottomThickness}" />
                <TextBlock Text="{Binding ResultSummary}" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
