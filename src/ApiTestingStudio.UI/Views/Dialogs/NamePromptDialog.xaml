<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.NamePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="400"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="{StaticResource Spacing.Lg.Thickness}">
        <TextBlock Text="{Binding Label}" />
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="{Binding Label}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource Spacing.Lg.TopThickness}">
            <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="{StaticResource Spacing.Sm.RightThickness}" />
            <Button Content="OK" IsDefault="True" MinWidth="80" IsEnabled="{Binding CanConfirm}" Click="OnConfirm" />
        </StackPanel>
    </StackPanel>
</Window>
