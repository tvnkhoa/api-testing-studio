<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.VariableEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="{StaticResource Spacing.Lg.Thickness}">
        <TextBlock Text="Key" />
        <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Key" />

        <TextBlock Text="Scope" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <ComboBox ItemsSource="{Binding Scopes}" SelectedItem="{Binding Scope}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                  AutomationProperties.Name="Scope" />

        <StackPanel Margin="{StaticResource Spacing.Md.TopThickness}">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEnvironmentScope}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="Environment" />
            <ComboBox ItemsSource="{Binding Environments}"
                      SelectedItem="{Binding SelectedEnvironment}"
                      DisplayMemberPath="Name"
                      Margin="{StaticResource Spacing.Xs.TopThickness}"
                      AutomationProperties.Name="Environment" />
        </StackPanel>

        <TextBlock Text="Value" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Value"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinLines="2" />

        <CheckBox Content="Secret (encrypt value at rest)" IsChecked="{Binding IsSecret}" Margin="{StaticResource Spacing.Md.TopThickness}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource Spacing.Lg.TopThickness}">
            <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="{StaticResource Spacing.Sm.RightThickness}" />
            <Button Content="OK" IsDefault="True" MinWidth="80" IsEnabled="{Binding CanConfirm}" Click="OnConfirm" />
        </StackPanel>
    </StackPanel>
</Window>
