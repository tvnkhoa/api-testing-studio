<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.ServiceEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="{StaticResource Spacing.Lg.Thickness}">
        <TextBlock Text="Name" />
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Name" />

        <TextBlock Text="Base URL" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Base URL" />

        <TextBlock Text="Description" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Description"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinLines="2" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource Spacing.Lg.TopThickness}">
            <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="{StaticResource Spacing.Sm.RightThickness}" />
            <Button Content="OK" IsDefault="True" MinWidth="80" IsEnabled="{Binding CanConfirm}" Click="OnConfirm" />
        </StackPanel>
    </StackPanel>
</Window>
