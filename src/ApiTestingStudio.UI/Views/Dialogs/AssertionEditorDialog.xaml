<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.AssertionEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="{StaticResource Spacing.Lg.Thickness}">
        <TextBlock Text="Type" />
        <ComboBox ItemsSource="{Binding Kinds}" SelectedItem="{Binding SelectedKind}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                  AutomationProperties.Name="Type" />

        <TextBlock Text="Source (response field)" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding Source}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                  AutomationProperties.Name="Source" />

        <TextBlock Text="Target (header name — for the Header source)" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <TextBox Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Target header name" />

        <TextBlock Text="Expression (JSONPath for json; regex pattern for regex)" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <TextBox Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Expression" />

        <TextBlock Text="Operator (json: equals / contains / exists / gt / lt …)" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <TextBox Text="{Binding Operator, UpdateSourceTrigger=PropertyChanged}" Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Operator" />

        <TextBlock Text="Expected (value, or the JSON Schema for the schema type)" Margin="{StaticResource Spacing.Md.TopThickness}" />
        <TextBox Text="{Binding Expected, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" VerticalScrollBarVisibility="Auto"
                 Margin="{StaticResource Spacing.Xs.TopThickness}"
                 AutomationProperties.Name="Expected value" />

        <CheckBox Content="Enabled" IsChecked="{Binding Enabled}" Margin="{StaticResource Spacing.Md.TopThickness}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource Spacing.Lg.TopThickness}">
            <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="{StaticResource Spacing.Sm.RightThickness}" />
            <Button Content="OK" IsDefault="True" MinWidth="80" IsEnabled="{Binding CanConfirm}" Click="OnConfirm" />
        </StackPanel>
    </StackPanel>
</Window>
