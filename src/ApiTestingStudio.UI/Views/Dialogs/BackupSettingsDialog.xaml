<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.BackupSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Backup &amp; Restore"
        Width="560"
        Height="460"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="{StaticResource Spacing.Lg.Thickness}">

        <TextBlock DockPanel.Dock="Top" Text="Backup settings" FontWeight="Bold" Margin="{StaticResource Spacing.Sm.BottomThickness}" />

        <StackPanel DockPanel.Dock="Top" Margin="{StaticResource Spacing.Md.BottomThickness}">
            <CheckBox Content="Automatically back up when the workspace is closed"
                      IsChecked="{Binding AutoBackupOnClose}" />
            <StackPanel Orientation="Horizontal" Margin="{StaticResource Spacing.Sm.TopThickness}">
                <TextBlock Text="Keep this many backups per workspace:" VerticalAlignment="Center" />
                <TextBox Width="60" Margin="{StaticResource Spacing.Sm.LeftThickness}"
                         Text="{Binding BackupRetention, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Save Settings" MinWidth="100" Margin="{StaticResource Spacing.Lg.LeftThickness}"
                        Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="Backups of this workspace" FontWeight="Bold" Margin="{StaticResource Spacing.Sm.VerticalThickness}" />

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="{StaticResource Spacing.Sm.TopThickness}"
                   TextWrapping="Wrap" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="{StaticResource Spacing.Md.TopThickness}">
            <Button Content="Close" IsCancel="True" MinWidth="80" />
        </StackPanel>

        <ListView ItemsSource="{Binding Backups}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Workspace" Width="160" DisplayMemberBinding="{Binding WorkspaceName}" />
                    <GridViewColumn Header="Created (UTC)" Width="170" DisplayMemberBinding="{Binding CreatedUtc}" />
                    <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeDisplay}" />
                    <GridViewColumn Header="" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Restore…"
                                        Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
