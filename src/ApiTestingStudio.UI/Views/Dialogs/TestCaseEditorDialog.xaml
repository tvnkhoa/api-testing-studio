<Window x:Class="ApiTestingStudio.UI.Views.Dialogs.TestCaseEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="Name" />
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />

        <TextBlock Text="Description" Margin="0,12,0,0" />
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />

        <TextBlock Text="Target (endpoint or workflow)" Margin="0,12,0,0" />
        <ComboBox ItemsSource="{Binding Targets}"
                  SelectedItem="{Binding SelectedTarget}"
                  DisplayMemberPath="Display"
                  Margin="0,4,0,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" IsCancel="True" MinWidth="80" Margin="0,0,8,0" />
            <Button Content="OK" IsDefault="True" MinWidth="80" IsEnabled="{Binding CanConfirm}" Click="OnConfirm" />
        </StackPanel>
    </StackPanel>
</Window>
