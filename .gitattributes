# Normalize line endings: Git stores text as LF, checks out native on each OS.
* text=auto

# Windows-native / VS-managed files stay CRLF
*.sln    text eol=crlf
*.slnx   text eol=crlf
*.csproj text eol=crlf
*.props  text eol=crlf
*.targets text eol=crlf
*.xaml   text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.ico binary
*.db  binary
*.sqlite binary
