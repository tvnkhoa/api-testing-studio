# Line-ending policy for this Windows-only .NET / WPF solution.
#
# Text is stored as LF in the repository and checked out as CRLF on every
# machine, matching .editorconfig (end_of_line = crlf). Pinning eol=crlf makes
# working trees deterministic regardless of each developer's core.autocrlf.
* text=auto eol=crlf

# Files that must stay LF even on Windows (shells / tooling).
*.sh   text eol=lf
*.bash text eol=lf

# Binary assets — never converted or diffed as text.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.db        binary
*.sqlite    binary
*.apistudio binary
*.zip       binary
*.dll       binary
*.exe       binary

# Vendored Monaco editor bundle (monaco-editor min/vs) — treat as opaque vendored
# assets: no line-ending conversion and no text diffing (see Assets/monaco/README.md).
src/ApiTestingStudio.UI/Assets/monaco/vs/** -text -diff
